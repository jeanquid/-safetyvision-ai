# SafetyVision AI — Environment Variables

# AI — Google Gemini (Google AI Studio key)
GEMINI_API_KEY=your_gemini_key_here

# Postgres DB
POSTGRES_URL=postgres://user:pass@host/db

# Authentication
JWT_SECRET=minimum-32-chars-secret-replace-in-prod

# CORS — allowed origins (comma-separated, no trailing slash)
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# Seed users (used only in npm run migrate)
SEED_ADMIN_EMAIL=admin@safetyvision.ai
SEED_ADMIN_PASSWORD=
SEED_INSPECTOR_EMAIL=inspector@safetyvision.ai
SEED_INSPECTOR_PASSWORD=

# n8n webhook for WhatsApp/email alerts (optional)
N8N_WEBHOOK_URL=https://your-n8n.com/webhook/safety-alert
